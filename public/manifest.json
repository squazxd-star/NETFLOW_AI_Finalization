{
  "manifest_version": 3,
  "name": "Netflow AI Video Automation",
  "version": "1.0",
  "description": "สร้างคลิปวิดีโอโฆษณาอัตโนมัติด้วย AI — จากสินค้าสู่วิดีโอพร้อมลง TikTok ในคลิกเดียว",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "clipboardWrite",
    "clipboardRead",
    "downloads",
    "downloads.open",
    "nativeMessaging"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Netflow AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/*"],
      "js": ["src/content-flow.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
