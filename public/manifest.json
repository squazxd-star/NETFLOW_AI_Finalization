{
    "manifest_version": 3,
    "name": "NetflowAI - Video Generator",
    "version": "1.0.0",
    "description": "AI-powered TikTok video generator with auto-upload",
    "permissions": [
        "activeTab",
        "storage",
        "unlimitedStorage",
        "scripting",
        "tabs",
        "sidePanel",
        "downloads"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    },
    "host_permissions": [
        "<all_urls>",
        "*://labs.google/*",
        "*://*.tiktok.com/*",
        "*://api.openai.com/*",
        "*://generativelanguage.googleapis.com/*",
        "*://aitestkitchen.withgoogle.com/*"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://labs.google/videofx*",
                "*://labs.google/fx/tools/video-fx*",
                "*://labs.google/*",
                "*://aitestkitchen.withgoogle.com/*"
            ],
            "js": [
                "src/content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.tiktok.com/tiktokstudio/*"
            ],
            "js": [
                "content/tiktok-uploader.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "Open NetflowAI"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "src/*",
                "locales/*",
                "fx/tools/*",
                "*.wasm",
                "*.js",
                "*.css",
                "*.json"
            ],
            "matches": ["<all_urls>"]
        }
    ]
}