{
  "manifest_version": 3,
  "name": "Netflow AI Video Automation",
  "version": "1.0",
  "description": "สร้างคลิปวิดีโอโฆษณาอัตโนมัติด้วย AI — จากสินค้าสู่วิดีโอพร้อมลง TikTok ในคลิกเดียว",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "clipboardWrite",
    "clipboardRead",
    "downloads",
    "downloads.open",
    "nativeMessaging"
  ],
  "host_permissions": [
    "file://*/*",
    "https://labs.google/*",
    "https://*.googleapis.com/*",
    "https://*.googleusercontent.com/*",
    "https://grok.com/*",
    "*://api.openai.com/*",
    "https://studio.youtube.com/*"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Netflow AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/*"],
      "js": ["src/content-flow.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["src/content-grok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://studio.youtube.com/*"
      ],
      "js": ["src/content-youtube-upload.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["themes/*.jpg", "themes/*.png", "themes/*.webp"],
      "matches": ["https://labs.google/*", "https://grok.com/*", "https://studio.youtube.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
